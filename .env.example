# Impatika environment configuration
# Copy to .env and fill in values.

# Anthropic API key. If unset, the report generator falls back to
# deterministic templates (the rest of the pipeline runs fully offline).
ANTHROPIC_API_KEY=

# Model used for EIA section drafting.
IMPATIKA_MODEL=claude-opus-4-7

# Directory holding environmental data layers (GeoJSON).
# Defaults to the bundled sample layers under data/sample.
IMPATIKA_DATA_DIR=
